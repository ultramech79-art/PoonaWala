# ========================================
# GoldEye Backend Configuration
# Copy this file to .env and fill in values
# ========================================

# ─── VLM Configuration (for S2, S8 VLM fallback) ─────────────────
# Options: http://localhost:11434/v1 (vLLM), Groq, Ollama, RunPod
VLM_API_URL=http://localhost:11434/v1
VLM_MODEL=qwen2.5vl
VLM_TIMEOUT_S=30
VLM_API_KEY=

# ─── Gemini / Groq API Configuration (PRIMARY for S3, S7, S11, fallbacks) ─
# Get Gemini key from: https://ai.google.dev/
# Get Groq key from: https://console.groq.com/
# Support multiple keys for failover (comma-separated, e.g. gemini_key,groq_key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_VERSION=v1beta
GEMINI_THINKING_LEVEL=minimal
# Optional: Dedicated Groq API Key
GROQ_API_KEY=

# ─── Database Configuration ──────────────────────────────────────
# SQLite for dev, PostgreSQL for production
DATABASE_URL=sqlite:///./goldeye.db
# For Postgres: postgresql+asyncpg://user:password@localhost:5432/goldeye

# ─── Redis Configuration (for caching, rate limiting) ────────────
REDIS_URL=redis://localhost:6379

# ─── Application Settings ───────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here

# ─── Poonawalla Deal Scraper (Phase 5) ──────────────────────────
# SerpAPI key for searching Poonawalla Fincorp gold loan pages
SERP_API_KEY=
# Groq key for LLM extraction (llama-3.3-70b-versatile)
# GROQ_API_KEY is already set above — same key used here

# ─── Pipecat Guided Session (Daily.co WebRTC) ───────────────────
# Get key from: https://dashboard.daily.co/developers
DAILY_API_KEY=
# Cartesia TTS (optional — falls back to edge-tts if not set)
# Get key from: https://play.cartesia.ai/
CARTESIA_API_KEY=

# ─── Feature Flags ─────────────────────────────────────────────
ENABLE_GEMINI=true
ENABLE_VLM_FALLBACK=true

# ========================================
# GoldEye Backend Configuration
# Copy this file to .env and fill in values
# ========================================

# ─── VLM Configuration (for S2, S8 VLM fallback) ─────────────────
# Options: http://localhost:11434/v1 (vLLM), Groq, Ollama, RunPod
VLM_API_URL=http://localhost:11434/v1
VLM_MODEL=qwen2.5vl
VLM_TIMEOUT_S=30
VLM_API_KEY=

# ─── Gemini / Groq API Configuration ────────────────────────────
# Get Gemini key from: https://ai.google.dev/
# Get Groq key from: https://console.groq.com/

# Gemini primary for raw audio/video analysis.
GEMINI_AUDIO_VIDEO_API_KEY=
# Gemini for live guidance and fallback for Groq-primary visual/document/decision calls.
GEMINI_GUIDANCE_FALLBACK_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_VERSION=v1beta
GEMINI_THINKING_LEVEL=minimal

# Groq primary keys for top view, 45-degree view, side view, bill/certificate OCR,
# hallmark/capture checks, price extraction, and non-audio/video decisions.
GROQ_PRIMARY_API_KEY_1=
GROQ_PRIMARY_API_KEY_2=
# Groq fallback for audio/video if Gemini audio/video fails.
GROQ_AUDIO_VIDEO_FALLBACK_API_KEY=
# Groq fallback for live guidance if Gemini guidance fails.
GROQ_GUIDANCE_FALLBACK_API_KEY=

# ─── Database Configuration ──────────────────────────────────────
# SQLite for dev, PostgreSQL for production
DATABASE_URL=sqlite:///./goldeye.db
# For Postgres: postgresql+asyncpg://user:password@localhost:5432/goldeye

# ─── Redis Configuration (for caching, rate limiting) ────────────
REDIS_URL=redis://localhost:6379

# ─── Application Settings ───────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here

# ─── Poonawalla Deal Scraper (Phase 5) ──────────────────────────
# SerpAPI key for searching Poonawalla Fincorp gold loan pages
SERP_API_KEY=
# Groq primary keys above are reused for LLM extraction.

# ─── Pipecat Guided Session (Daily.co WebRTC) ───────────────────
# Get key from: https://dashboard.daily.co/developers
DAILY_API_KEY=
# Cartesia TTS (optional — falls back to edge-tts if not set)
# Get key from: https://play.cartesia.ai/
CARTESIA_API_KEY=

# ─── Feature Flags ─────────────────────────────────────────────
ENABLE_GEMINI=true
ENABLE_VLM_FALLBACK=true

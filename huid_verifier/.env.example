# ── Appium server ───────────────────────────────────────────────────────────────
APPIUM_URL=http://127.0.0.1:4723

# ── Android device / emulator ───────────────────────────────────────────────────
# Run:  adb devices   to find your UDID
DEVICE_UDID=emulator-5554
DEVICE_NAME=Android Emulator
PLATFORM_VERSION=14.0

# ── BIS CARE app ────────────────────────────────────────────────────────────────
BIS_PACKAGE=com.bis.bisapp
# Leave BIS_ACTIVITY blank — Appium resolves the launcher activity automatically.
# Set it only after running:  scripts/detect_bis_activity.sh
BIS_ACTIVITY=

# ── Timeouts (seconds) ───────────────────────────────────────────────────────────
APPIUM_NEW_COMMAND_TIMEOUT=120
ELEMENT_WAIT_TIMEOUT=15
RESULT_WAIT_TIMEOUT=20

# ── File paths ───────────────────────────────────────────────────────────────────
SCREENSHOTS_DIR=screenshots

# ── FastAPI server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO
